<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Clínica Nerea Torres — Medicina Estética</title>
    <meta name="description" content="Clínica médico estética Nerea Torres. Tratamientos para acné, antiaging, despigmentantes y más.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        /* ═══════════════════════════════════════
           RESET & VARIABLES
           ═══════════════════════════════════════ */
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --blanco-roto: #FAF8F5;
            --gris-tapioca: #E8E0D8;
            --nude: #D4C5B9;
            --nude-oscuro: #C9B8A8;
            --gris-calido: #9A8E82;
            --negro-suave: #2C2824;
            --negro: #1A1714;
            --dorado: #B8A080;
            --serif: 'Cormorant Garamond', Georgia, serif;
            --sans: 'Montserrat', -apple-system, sans-serif;
            --max-width: 1200px;
            --transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        html {
            scroll-behavior: smooth;
            font-size: 16px;
        }

        body {
            font-family: var(--sans);
            font-weight: 300;
            color: var(--negro-suave);
            background: var(--blanco-roto);
            line-height: 1.7;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
        }

        /* ═══════════════════════════════════════
           TYPOGRAPHY
           ═══════════════════════════════════════ */
        h1, h2, h3, h4 {
            font-family: var(--serif);
            font-weight: 300;
            letter-spacing: 0.04em;
        }

        h1 { font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.1; }
        h2 { font-size: clamp(2rem, 4vw, 3rem); line-height: 1.2; }
        h3 { font-size: clamp(1.3rem, 2.5vw, 1.8rem); line-height: 1.3; }

        .label {
            font-family: var(--sans);
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--gris-calido);
        }

        /* ═══════════════════════════════════════
           NAVIGATION
           ═══════════════════════════════════════ */
        .nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            padding: 1.5rem 3rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: var(--transition);
            background: transparent;
        }

        .nav.scrolled {
            background: rgba(250, 248, 245, 0.95);
            backdrop-filter: blur(20px);
            padding: 1rem 3rem;
            box-shadow: 0 1px 0 var(--gris-tapioca);
        }

        .nav-logo {
            font-family: var(--serif);
            font-size: 1.1rem;
            font-weight: 400;
            letter-spacing: 0.15em;
            color: var(--negro);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.8rem;
        }

        .nav-logo .iso {
            width: 32px;
            height: 32px;
            opacity: 0.9;
        }

        .nav-links {
            display: flex;
            gap: 2.5rem;
            list-style: none;
        }

        .nav-links a {
            font-size: 0.75rem;
            font-weight: 400;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--negro-suave);
            text-decoration: none;
            transition: var(--transition);
            position: relative;
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 1px;
            background: var(--dorado);
            transition: var(--transition);
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        .nav-toggle {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            padding: 5px;
        }

        .nav-toggle span {
            width: 24px;
            height: 1.5px;
            background: var(--negro);
            transition: var(--transition);
        }

        /* ═══════════════════════════════════════
           HERO
           ═══════════════════════════════════════ */
        .hero {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 6rem 2rem;
            background: var(--blanco-roto);
            position: relative;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, var(--gris-tapioca) 0%, transparent 70%);
            opacity: 0.4;
            pointer-events: none;
        }

        .hero-content {
            position: relative;
            z-index: 1;
            max-width: 800px;
        }

        .hero .label {
            margin-bottom: 2rem;
            color: var(--nude-oscuro);
        }

        .hero h1 {
            margin-bottom: 1.5rem;
            color: var(--negro);
        }

        .hero h1 em {
            font-style: italic;
            font-weight: 300;
            color: var(--gris-calido);
        }

        .hero p {
            font-size: 1.1rem;
            color: var(--gris-calido);
            max-width: 500px;
            margin: 0 auto 3rem;
            font-weight: 300;
        }

        .btn {
            display: inline-block;
            padding: 1rem 2.5rem;
            font-family: var(--sans);
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            text-decoration: none;
            border: 1px solid var(--negro);
            color: var(--negro);
            background: transparent;
            cursor: pointer;
            transition: var(--transition);
        }

        .btn:hover {
            background: var(--negro);
            color: var(--blanco-roto);
        }

        .btn-filled {
            background: var(--negro);
            color: var(--blanco-roto);
        }

        .btn-filled:hover {
            background: var(--negro-suave);
            border-color: var(--negro-suave);
        }

        .scroll-indicator {
            position: absolute;
            bottom: 3rem;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
            color: var(--gris-calido);
            font-size: 0.65rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            animation: float 3s ease-in-out infinite;
        }

        .scroll-indicator .line {
            width: 1px;
            height: 40px;
            background: linear-gradient(to bottom, var(--gris-calido), transparent);
        }

        @keyframes float {
            0%, 100% { transform: translateX(-50%) translateY(0); }
            50% { transform: translateX(-50%) translateY(10px); }
        }

        /* ═══════════════════════════════════════
           SECTIONS COMMON
           ═══════════════════════════════════════ */
        section {
            padding: 8rem 2rem;
        }

        .section-inner {
            max-width: var(--max-width);
            margin: 0 auto;
        }

        .section-header {
            text-align: center;
            margin-bottom: 5rem;
        }

        .section-header .label {
            margin-bottom: 1rem;
        }

        .section-header p {
            max-width: 600px;
            margin: 1.5rem auto 0;
            color: var(--gris-calido);
            font-size: 1rem;
        }

        .divider {
            width: 60px;
            height: 1px;
            background: var(--nude);
            margin: 2rem auto;
        }

        /* ═══════════════════════════════════════
           ABOUT
           ═══════════════════════════════════════ */
        .about {
            background: white;
        }

        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 5rem;
            align-items: center;
        }

        .about-image {
            aspect-ratio: 3/4;
            background: var(--gris-tapioca);
            position: relative;
            overflow: hidden;
        }

        .about-image::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, transparent 60%, rgba(212, 197, 185, 0.3));
        }

        .about-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .about-text h2 {
            margin-bottom: 1.5rem;
        }

        .about-text p {
            margin-bottom: 1.5rem;
            color: var(--gris-calido);
        }

        .about-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            margin-top: 3rem;
            padding-top: 3rem;
            border-top: 1px solid var(--gris-tapioca);
        }

        .stat-number {
            font-family: var(--serif);
            font-size: 2.5rem;
            font-weight: 300;
            color: var(--negro);
            line-height: 1;
        }

        .stat-label {
            font-size: 0.7rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--gris-calido);
            margin-top: 0.5rem;
        }

        /* ═══════════════════════════════════════
           SERVICES
           ═══════════════════════════════════════ */
        .services {
            background: var(--blanco-roto);
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
        }

        .service-card {
            background: white;
            padding: 3rem 2rem;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .service-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: var(--dorado);
            transform: scaleX(0);
            transform-origin: left;
            transition: var(--transition);
        }

        .service-card:hover::before {
            transform: scaleX(1);
        }

        .service-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.05);
        }

        .service-icon {
            width: 48px;
            height: 48px;
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .service-icon svg {
            width: 100%;
            height: 100%;
            stroke: var(--nude-oscuro);
            fill: none;
            stroke-width: 1;
        }

        .service-card h3 {
            margin-bottom: 1rem;
            font-size: 1.4rem;
        }

        .service-card p {
            color: var(--gris-calido);
            font-size: 0.9rem;
            line-height: 1.8;
        }

        .service-card .service-link {
            display: inline-block;
            margin-top: 1.5rem;
            font-size: 0.7rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--dorado);
            text-decoration: none;
            transition: var(--transition);
        }

        .service-card .service-link:hover {
            color: var(--negro);
        }

        /* ═══════════════════════════════════════
           PHILOSOPHY
           ═══════════════════════════════════════ */
        .philosophy {
            background: var(--negro);
            color: var(--blanco-roto);
            text-align: center;
        }

        .philosophy h2 {
            color: var(--blanco-roto);
            font-size: clamp(1.8rem, 4vw, 3rem);
            max-width: 800px;
            margin: 0 auto 2rem;
            line-height: 1.4;
        }

        .philosophy h2 em {
            color: var(--dorado);
        }

        .philosophy p {
            max-width: 600px;
            margin: 0 auto;
            color: var(--nude);
            font-size: 1rem;
        }

        /* ═══════════════════════════════════════
           TESTIMONIALS
           ═══════════════════════════════════════ */
        .testimonials {
            background: white;
        }

        .testimonials-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 3rem;
        }

        .testimonial {
            padding: 2.5rem;
            background: var(--blanco-roto);
            position: relative;
        }

        .testimonial::before {
            content: '"';
            font-family: var(--serif);
            font-size: 5rem;
            color: var(--gris-tapioca);
            position: absolute;
            top: 0.5rem;
            left: 1.5rem;
            line-height: 1;
        }

        .testimonial p {
            font-family: var(--serif);
            font-size: 1.15rem;
            font-style: italic;
            line-height: 1.8;
            color: var(--negro-suave);
            margin-bottom: 1.5rem;
            position: relative;
            z-index: 1;
        }

        .testimonial-author {
            font-size: 0.75rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--gris-calido);
            font-weight: 500;
        }

        /* ═══════════════════════════════════════
           CONTACT
           ═══════════════════════════════════════ */
        .contact {
            background: var(--blanco-roto);
        }

        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 5rem;
        }

        .contact-info h2 {
            margin-bottom: 1.5rem;
        }

        .contact-info p {
            color: var(--gris-calido);
            margin-bottom: 2rem;
        }

        .contact-details {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .contact-item {
            display: flex;
            gap: 1rem;
            align-items: flex-start;
        }

        .contact-item .icon {
            width: 20px;
            height: 20px;
            flex-shrink: 0;
            margin-top: 2px;
            color: var(--dorado);
        }

        .contact-item .text {
            font-size: 0.9rem;
        }

        .contact-item .text strong {
            display: block;
            font-weight: 500;
            margin-bottom: 0.2rem;
        }

        .contact-item .text span {
            color: var(--gris-calido);
        }

        .contact-form {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .form-group label {
            font-size: 0.7rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--gris-calido);
            font-weight: 500;
        }

        .form-group input,
        .form-group textarea,
        .form-group select {
            padding: 1rem;
            border: 1px solid var(--gris-tapioca);
            background: white;
            font-family: var(--sans);
            font-size: 0.9rem;
            font-weight: 300;
            color: var(--negro);
            transition: var(--transition);
            outline: none;
        }

        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            border-color: var(--dorado);
        }

        .form-group textarea {
            resize: vertical;
            min-height: 120px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }

        /* ═══════════════════════════════════════
           FOOTER
           ═══════════════════════════════════════ */
        .footer {
            background: var(--negro);
            color: var(--nude);
            padding: 4rem 2rem 2rem;
        }

        .footer-inner {
            max-width: var(--max-width);
            margin: 0 auto;
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            gap: 3rem;
        }

        .footer-brand h3 {
            font-family: var(--serif);
            font-size: 1.3rem;
            color: var(--blanco-roto);
            margin-bottom: 1rem;
            letter-spacing: 0.1em;
        }

        .footer-brand p {
            font-size: 0.85rem;
            line-height: 1.8;
            color: var(--gris-calido);
        }

        .footer-col h4 {
            font-family: var(--sans);
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--blanco-roto);
            margin-bottom: 1.5rem;
        }

        .footer-col ul {
          